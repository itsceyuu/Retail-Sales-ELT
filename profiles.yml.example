retail_sales_elt:
  target: dev
  outputs:
    dev:
      type: clickhouse
      threads: 1
      host: "{{ env_var('CH_HOST', 'localhost') }}"
      port: "{{ env_var('CH_PORT', '8123') | int }}"
      user: "{{ env_var('CH_USER', 'admin') }}"
      password: "{{ env_var('CH_PASSWORD', 'admin123') }}"
      database: "{{ env_var('CH_DATABASE', 'bronze') }}"
      schema: "{{ env_var('CH_DATABASE', 'bronze') }}"
